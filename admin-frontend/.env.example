# Admin Frontend Environment Variables
# Copy this file to .env and fill in your real values

# URL of the backend API (NestJS)
# Local: full URL. Vercel: use /api (proxied in vercel.json).
# Production Vercel: use /api (proxied in vercel.json). Do NOT use https://backend.vercel.app/api
VITE_API_URL=/api

# Optional: link to admin from public site header
VITE_ADMIN_URL=http://localhost:5174

# WebSocket URL
VITE_WS_URL=http://localhost:3001
