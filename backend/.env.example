# Backend Environment Variables
# Copy this file to .env and fill in your real values

# ------- Database (Supabase PostgreSQL) -------
# Voir SUPABASE-SETUP.md pour le guide complet.
#
# DATABASE_URL = pooler Transaction, port 6543 (API + Vercel)
# postgresql://postgres.[ref]:[PASSWORD]@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# DIRECT_URL = connexion directe, port 5432 (prisma migrate deploy)
# postgresql://postgres.[ref]:[PASSWORD]@aws-0-xxx.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ------- Redis -------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------- JWT -------
JWT_SECRET=change_me_generate_a_long_random_secret

# Required to create additional admins after the first one (optional for bootstrap)
ADMIN_REGISTRATION_SECRET=change_me_long_random_secret
JWT_EXPIRES_IN=15m

# ------- Stripe (optionnel) -------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ------- Supabase Storage (même projet Supabase) -------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Backend uploads : préférer service_role (Settings → API), pas anon
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_BUCKET=portfolio

# Image optimization before Supabase upload (Sharp)
IMAGE_OPTIMIZE=true
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1920
IMAGE_JPEG_QUALITY=82
IMAGE_WEBP_QUALITY=82
IMAGE_MIN_BYTES=150000

# ------- Email (SendGrid) -------
SENDGRID_API_KEY=SG.YOUR_KEY
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=L Benna Studio
ADMIN_EMAIL=admin@yourdomain.com

# ------- App -------
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ------- Upload limits -------
MAX_FILE_SIZE=50MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/tiff,application/pdf

# ------- Flouci Payment (Tunisie) -------
FLOUCI_APP_TOKEN=your-flouci-app-token
FLOUCI_APP_SECRET=your-flouci-app-secret
FLOUCI_API_URL=https://api.flouci.com
FLOUCI_SUCCESS_URL=http://localhost:3000/payment/success
FLOUCI_FAIL_URL=http://localhost:3000/payment/fail

# ------- License -------
LICENSE_JWT_SECRET=change_me_long_random_secret
LICENSE_EXPIRES_IN=30d
