// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id          String    @id @default(cuid())
  userId      String
  type        String    // "order_update", "payment_success", etc.
  title       String
  message     String
  isRead      Boolean   @default(false)
  data        Json?     // Données additionnelles
  createdAt   DateTime  @default(now())
  readAt      DateTime?
  
  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}