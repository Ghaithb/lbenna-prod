# Workspace-wide example env
# Copy to .env or create environment variables in your deployment

# Frontend
VITE_API_URL=http://localhost:3001/api
VITE_ADMIN_URL=http://localhost:3002

# Common
NODE_ENV=development

# Backend
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/photoskop?schema=public
JWT_SECRET=changeme_generate_a_secure_random_value
REDIS_URL=redis://localhost:6379

# Storage (S3 compatible)
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
