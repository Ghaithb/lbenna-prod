// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================
// SERVICES AUDIOVISUELS
// =============================

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  REVIEW
  COMPLETED
  DELIVERED
  ARCHIVED
}

enum ProjectType {
  VIDEO
  PHOTO
  AUDIO
  MIXED
}

model Project {
  id          String       @id @default(cuid())
  title       String
  type        ProjectType
  status      ProjectStatus
  clientId    String
  description String?      @db.Text
  duration    Int?         // En minutes
  startDate   DateTime
  dueDate     DateTime?
  budget      Float?
  notes       String?      @db.Text
  
  // Relations
  client      Client       @relation(fields: [clientId], references: [id])
  mediaFiles  MediaFile[]
  tasks       Task[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("projects")
}

model MediaFile {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  type        String    // video, audio, image
  url         String
  format      String    // mp4, wav, jpg, etc.
  size        Int       // En bytes
  duration    Int?      // En secondes pour audio/video
  metadata    Json?     // Données techniques
  
  project     Project   @relation(fields: [projectId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("media_files")
}

model Task {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      String    // TODO, IN_PROGRESS, COMPLETED
  dueDate     DateTime?
  
  project     Project   @relation(fields: [projectId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("tasks")
}

// =============================
// VENTE ET LOCATION MATÉRIEL
// =============================

enum ProductCategory {
  CAMERA
  LENS
  LIGHTING
  AUDIO
  DRONE
  ACCESSORY
  STUDIO
}

enum ProductStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  DISCONTINUED
}

model Product {
  id            String         @id @default(cuid())
  name          String
  category      ProductCategory
  description   String         @db.Text
  price         Float
  rentalPrice   Float?         // Prix location/jour
  stock         Int
  status        ProductStatus
  brand         String?
  model         String?
  serialNumber  String?        @unique
  features      Json?          // Caractéristiques techniques
  images        String[]       // URLs des images
  
  // Relations
  orderItems    OrderItem[]
  rentalItems   RentalItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("products")
}

// =============================
// TIRAGE ET IMPRESSION
// =============================

enum PaperType {
  MATTE
  GLOSSY
  SATIN
  METALLIC
  CANVAS
  FINE_ART
}

enum PrintSize {
  S_10X15    // 10x15cm
  M_13X18    // 13x18cm
  L_20X30    // 20x30cm
  XL_30X45   // 30x45cm
  XXL_50X75  // 50x75cm
  CUSTOM     // Taille personnalisée
}

model PrintOrder {
  id          String     @id @default(cuid())
  clientId    String
  status      String     // PENDING, PRINTING, READY, COMPLETED
  paperType   PaperType
  size        PrintSize
  quantity    Int
  imageUrl    String
  notes       String?
  
  // Pour tailles personnalisées
  customWidth  Int?
  customHeight Int?
  
  // Relations
  client      Client    @relation(fields: [clientId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("print_orders")
}

// =============================
// SUBLIMATION
// =============================

enum SublimationType {
  MUG
  TSHIRT
  MOUSEPAD
  PHONE_CASE
  CUSHION
  CUSTOM
}

model SublimationProduct {
  id          String          @id @default(cuid())
  type        SublimationType
  name        String
  description String?
  basePrice   Float
  dimensions  String?         // Format "LxHxP"
  material    String?
  colors      String[]
  
  // Relations
  orders      SublimationOrder[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("sublimation_products")
}

model SublimationOrder {
  id          String             @id @default(cuid())
  productId   String
  clientId    String
  designUrl   String
  quantity    Int
  color       String?
  notes       String?
  status      String             // PENDING, PRODUCTION, COMPLETED
  
  // Relations
  product     SublimationProduct @relation(fields: [productId], references: [id])
  client      Client             @relation(fields: [clientId], references: [id])
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("sublimation_orders")
}

// =============================
// CLIENTS ET COMMANDES
// =============================

enum ClientType {
  INDIVIDUAL
  BUSINESS
  STUDENT
}

model Client {
  id          String       @id @default(cuid())
  type        ClientType   @default(INDIVIDUAL)
  firstName   String
  lastName    String
  email       String       @unique
  phone       String?
  address     String?
  company     String?      // Pour clients business
  
  // Relations
  projects         Project[]
  orders           Order[]
  printOrders      PrintOrder[]
  sublimationOrders SublimationOrder[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@map("clients")
}

model Order {
  id          String      @id @default(cuid())
  clientId    String
  status      String      // PENDING, PAID, SHIPPED, COMPLETED
  total       Float
  
  // Relations
  client      Client      @relation(fields: [clientId], references: [id])
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("orders")
}

model OrderItem {
  id          String    @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  unitPrice   Float
  
  // Relations
  order       Order     @relation(fields: [orderId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// =============================
// LOCATION DE MATÉRIEL
// =============================

model Rental {
  id          String       @id @default(cuid())
  clientId    String
  startDate   DateTime
  endDate     DateTime
  status      String       // PENDING, ACTIVE, RETURNED, CANCELLED
  deposit     Float
  totalCost   Float
  notes       String?
  
  // Relations
  client      Client       @relation(fields: [clientId], references: [id])
  items       RentalItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("rentals")
}

model RentalItem {
  id          String    @id @default(cuid())
  rentalId    String
  productId   String
  quantity    Int
  dailyRate   Float
  
  // Relations
  rental      Rental    @relation(fields: [rentalId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@map("rental_items")
}

// =============================
// FORMATION ET APPRENTISSAGE
// =============================

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Course {
  id          String      @id @default(cuid())
  title       String
  description String      @db.Text
  level       CourseLevel
  status      CourseStatus
  duration    Int         // En minutes
  price       Float
  thumbnail   String?
  objectives  String[]    // Objectifs d'apprentissage
  requirements String[]   // Prérequis
  
  // Relations
  instructor   User       @relation("InstructorCourses", fields: [instructorId], references: [id])
  instructorId String
  modules      Module[]
  enrollments  Enrollment[]
  reviews      CourseReview[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("courses")
}

model Module {
  id          String    @id @default(cuid())
  courseId    String
  title       String
  description String    @db.Text
  order       Int       // Ordre dans le cours
  duration    Int       // En minutes
  
  // Relations
  course      Course    @relation(fields: [courseId], references: [id])
  lessons     Lesson[]
  progress    ModuleProgress[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("modules")
}

model Lesson {
  id          String    @id @default(cuid())
  moduleId    String
  title       String
  content     String    @db.Text
  videoUrl    String?
  duration    Int       // En minutes
  order       Int      // Ordre dans le module
  
  // Relations
  module      Module    @relation(fields: [moduleId], references: [id])
  resources   Resource[]
  exercises   Exercise[]
  progress    LessonProgress[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("lessons")
}

model Resource {
  id          String    @id @default(cuid())
  lessonId    String
  title       String
  type        String    // PDF, IMAGE, VIDEO, etc.
  url         String
  description String?
  
  // Relations
  lesson      Lesson    @relation(fields: [lessonId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("resources")
}

enum ExerciseType {
  QUIZ
  PRACTICAL
  PHOTO_ASSIGNMENT
  CAMERA_SIMULATION
}

model Exercise {
  id          String       @id @default(cuid())
  lessonId    String
  title       String
  type        ExerciseType
  description String       @db.Text
  content     Json        // Questions, options, instructions
  duration    Int         // Temps estimé en minutes
  
  // Relations
  lesson      Lesson       @relation(fields: [lessonId], references: [id])
  submissions ExerciseSubmission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("exercises")
}

model ExerciseSubmission {
  id          String    @id @default(cuid())
  exerciseId  String
  userId      String
  content     Json      // Réponses, images soumises
  score       Float?    // Note sur 100
  feedback    String?   @db.Text
  
  // Relations
  exercise    Exercise  @relation(fields: [exerciseId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("exercise_submissions")
}

model Enrollment {
  id          String    @id @default(cuid())
  courseId    String
  userId      String
  status      String    // ACTIVE, COMPLETED, CANCELLED
  progress    Float     // Pourcentage de progression
  startDate   DateTime  @default(now())
  completedAt DateTime?
  
  // Relations
  course      Course    @relation(fields: [courseId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  moduleProgress ModuleProgress[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("enrollments")
}

model ModuleProgress {
  id           String    @id @default(cuid())
  enrollmentId String
  moduleId     String
  progress     Float     // Pourcentage de progression
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  
  // Relations
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  module       Module     @relation(fields: [moduleId], references: [id])
  lessonProgress LessonProgress[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("module_progress")
}

model LessonProgress {
  id              String    @id @default(cuid())
  moduleProgressId String
  lessonId        String
  status          String    // NOT_STARTED, IN_PROGRESS, COMPLETED
  timeSpent       Int       // Temps passé en secondes
  completedAt     DateTime?
  
  // Relations
  moduleProgress  ModuleProgress @relation(fields: [moduleProgressId], references: [id])
  lesson          Lesson    @relation(fields: [lessonId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("lesson_progress")
}

model CourseReview {
  id          String    @id @default(cuid())
  courseId    String
  userId      String
  rating      Int       // 1-5
  comment     String    @db.Text
  
  // Relations
  course      Course    @relation(fields: [courseId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("course_reviews")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  firstName     String
  lastName      String
  role          String     // STUDENT, INSTRUCTOR, ADMIN
  bio          String?    @db.Text
  avatar       String?
  
  // Relations
  coursesTeaching Course[] @relation("InstructorCourses")
  enrollments     Enrollment[]
  submissions     ExerciseSubmission[]
  reviews         CourseReview[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("users")
}