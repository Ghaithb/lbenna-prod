# Backend Environment Variables
# Copy this file to .env and fill in your real values

# ------- Database -------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public"

# ------- Redis -------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------- JWT -------
JWT_SECRET=change_me_generate_a_long_random_secret
JWT_EXPIRES_IN=15m

# ------- Stripe (optionnel) -------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ------- Supabase Storage -------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_BUCKET=portfolio

# ------- Email (SendGrid) -------
SENDGRID_API_KEY=SG.YOUR_KEY
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=L Benna Studio
ADMIN_EMAIL=admin@yourdomain.com

# ------- App -------
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ------- Upload limits -------
MAX_FILE_SIZE=50MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/tiff,application/pdf

# ------- Flouci Payment (Tunisie) -------
FLOUCI_APP_TOKEN=your-flouci-app-token
FLOUCI_APP_SECRET=your-flouci-app-secret
FLOUCI_API_URL=https://api.flouci.com
FLOUCI_SUCCESS_URL=http://localhost:3000/payment/success
FLOUCI_FAIL_URL=http://localhost:3000/payment/fail

# ------- License -------
LICENSE_JWT_SECRET=change_me_long_random_secret
LICENSE_EXPIRES_IN=30d
